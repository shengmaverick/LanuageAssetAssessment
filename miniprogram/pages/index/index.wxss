/* pages/index/index.wxss */

/* Hero 区域 */
.hero {
  position: relative;
  background: linear-gradient(145deg, #1a3bc0 0%, #2B5CE6 50%, #5B7FEE 100%);
  padding: 60rpx 32rpx 0;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

.hero-content {
  position: relative;
  z-index: 1;
  color: #fff;
  padding-bottom: 32rpx;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  display: block;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 22rpx;
  opacity: 0.75;
  font-style: italic;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.hero-desc {
  font-size: 26rpx;
  opacity: 0.9;
  line-height: 1.6;
}

.hero-stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255,255,255,0.12);
  border-radius: 20rpx 20rpx 0 0;
  padding: 28rpx 20rpx;
  margin-top: 28rpx;
  position: relative;
  z-index: 1;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.25);
}

/* 章节标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #666;
  padding: 32rpx 32rpx 16rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* 维度卡片横向滚动 */
.dimensions-scroll {
  padding: 0 24rpx;
  white-space: nowrap;
}

.dimensions-row {
  display: flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.dim-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  min-width: 160rpx;
  flex-shrink: 0;
}

.dim-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.dim-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.3;
}

.dim-count {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(43, 92, 230, 0.08);
}

.form-tip {
  font-size: 24rpx;
  color: #888;
  background: #f8f9fd;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.required {
  color: #EF4444;
  margin-right: 6rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F7FF;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #2B5CE6;
  background: #fff;
}

.input-placeholder {
  color: #bbb;
  font-size: 28rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: #F5F7FF;
  border-radius: 14rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #bbb;
}

.form-picker.picker-selected {
  color: #333;
}

.picker-arrow {
  font-size: 36rpx;
  color: #ccc;
  transform: rotate(90deg);
  display: inline-block;
}

/* 开始按钮 */
.start-section {
  padding: 40rpx 32rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.start-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
}

.start-btn.active {
  background: linear-gradient(135deg, #2B5CE6, #6C8EF5);
  color: #fff;
  box-shadow: 0 8rpx 28rpx rgba(43, 92, 230, 0.4);
}

.start-btn.disabled {
  background: #ddd;
  color: #aaa;
  box-shadow: none;
}

.start-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  text-align: center;
}
